+void readcolonargs(char **p, int cursor, int params[][CAR_PER_ARG]) {
+  int i = 0;
+  for (; i < CAR_PER_ARG; i++)
+    params[cursor][i] = -1;
+
+  if (**p != ':')
+    return;
+
+  char *np = NULL;
+  i = 0;
+
+  while (**p == ':' && i < CAR_PER_ARG) {
+    while (**p == ':')
+      (*p)++;
+    params[cursor][i] = strtol(*p, &np, 10);
+    *p = np;
+    i++;
+  }
+}
